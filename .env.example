# Publishing credentials for scripts/publish.py
# Copy this file to .env and fill in your values (never commit .env)

# Anthropic - used by /publish-hugo-article skill for generating hooks + hashtags
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Medium - Personal Integration Token
# Get from: https://medium.com/me/settings -> Integration tokens
MEDIUM_TOKEN=
# Get your author ID by running: python scripts/publish.py --whoami-medium
MEDIUM_AUTHOR_ID=

# LinkedIn OAuth2 - get by running: python scripts/linkedin_auth.py --client-id X --client-secret Y
# First create an app at: https://www.linkedin.com/developers/apps
# Required scopes: w_member_social, r_liteprofile, openid, profile, email
# Redirect URL in app settings: http://localhost:8080/callback
# Tokens expire after ~60 days — re-run linkedin_auth.py to refresh
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_PERSON_URN=

# X (Twitter) OAuth1.0a - get by running: python scripts/x_auth.py --api-key X --api-secret Y
# First create an app at: https://developer.x.com
# App must have "Read and Write" permissions enabled
# X tokens do not expire unless revoked
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
